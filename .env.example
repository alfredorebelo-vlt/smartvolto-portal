# =============================================================
# Volto Smart Portal — variáveis de ambiente necessárias
# Copia este ficheiro para .env.local e preenche os valores
# NUNCA cometes o ficheiro .env.local para o Git
# =============================================================

# Base de dados MariaDB
# Formato: mysql://utilizador:password@host:3306/nome_base_dados
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME

# NextAuth v5
# Gera com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=gera_com_openssl_rand_base64_32
AUTH_TRUST_HOST=true

# Google OAuth (Google Cloud Console → Credenciais)
AUTH_GOOGLE_ID=xxxxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-xxxxx

# URL pública da aplicação
NEXTAUTH_URL=https://voltosmart.voltodrive.com

# Google Workspace Directory — Service Account com Domain-Wide Delegation
GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@voltodrive.com
GOOGLE_WORKSPACE_CLIENT_EMAIL=service-account@projecto.iam.gserviceaccount.com
GOOGLE_WORKSPACE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GOOGLE_WORKSPACE_DOMAIN=voltodrive.com
